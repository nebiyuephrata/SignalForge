APP_NAME=SignalForge
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=10000
BASE_URL=https://your-public-signalforge-url.example.com
LOG_LEVEL=INFO
FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
