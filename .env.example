CAL_API_KEY=
CALCOM_BASE_URL=https://cal.com
CALCOM_BOOKING_SLUG=signalforge-discovery
CALCOM_WEBHOOK_SECRET=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001

REDIS_URL=redis://localhost:6379/0
